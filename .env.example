# Copy this file to .env and edit it for your deployment.
#
# Keep values in simple KEY=value form without shell quotes or spaces around
# "=". Explicit variables supplied when running ./startup.sh take precedence
# over this file. Docker Compose shell overrides take precedence for variables
# mapped in docker-compose.yml.

# -----------------------------------------------------------------------------
# Inference LLM
# -----------------------------------------------------------------------------

# LLM provider used by the inference service and as the app's initial
# translation provider. Supported values: openai, ollama.
INFERENCE_LLM_PROVIDER=openai

# Model name understood by the selected provider.
# OpenAI example: gpt-5.4-mini
# Ollama example: llama3.2
INFERENCE_LLM_MODEL=gpt-5.4-mini

# Required only when INFERENCE_LLM_PROVIDER=openai.
OPENAI_API_KEY=your-openai-api-key-here

# Optional Ollama endpoint override.
#
# Leave this unset for the standard configurations:
# - ./startup.sh defaults to http://localhost:11434
# - Docker Compose defaults to http://host.docker.internal:11434
#
# Set it only when Ollama is running at another address. Do not set it to
# localhost for Docker Compose because localhost inside a container refers to
# that container, not the Docker host.
# OLLAMA_BASE_URL=http://ollama-server:11434

# -----------------------------------------------------------------------------
# CODA web app
# -----------------------------------------------------------------------------

# Interface and port where the web app listens.
# Keep APP_HOST=0.0.0.0 for Docker or remote access. Use 127.0.0.1 to restrict
# a local source deployment to the current machine.
APP_HOST=0.0.0.0
APP_PORT=8000

# -----------------------------------------------------------------------------
# Inference service
# -----------------------------------------------------------------------------

# Interface and port where the inference API listens.
# Keep INFERENCE_HOST=0.0.0.0 for Docker. The inference API is published on
# INFERENCE_PORT by the current Compose configuration.
INFERENCE_HOST=0.0.0.0
INFERENCE_PORT=5123

# URL used by the app to contact the inference service.
#
# Normally leave this unset:
# - ./startup.sh derives http://127.0.0.1:<INFERENCE_PORT>
# - Docker Compose derives http://inference:<INFERENCE_PORT>
#
# Set it when the app and inference service run on different hosts or outside
# the standard startup/Compose topology.
# INFERENCE_URL=http://inference-host:5123

# -----------------------------------------------------------------------------
# RAG grounder
# -----------------------------------------------------------------------------

# These settings are independent from INFERENCE_LLM_PROVIDER and
# INFERENCE_LLM_MODEL. They are used only when the RAG grounder is selected.
RAG_LLM_PROVIDER=openai
RAG_LLM_MODEL=gpt-4o-mini

# Ontology vector index queried by the RAG grounder.
RAG_ONTOLOGY=icd10

# Whether the RAG grounder reranks retrieved candidates with its LLM.
RAG_USE_RERANKER=true

# URL used by the RAG grounder to contact Neo4j.
#
# Normally leave this unset:
# - local Python processes default to bolt://localhost:7687
# - Docker Compose defaults to bolt://kg:7687
#
# Set it when Neo4j runs on another host or outside the standard Compose
# topology.
# CODA_KG_URL=bolt://neo4j-host:7687

# -----------------------------------------------------------------------------
# Whisper compute device
# -----------------------------------------------------------------------------

# Runtime device used by Whisper. Supported values: cpu, cuda.
# Leave unset for the CPU default. A CUDA deployment also requires a
# CUDA-capable PyTorch build and GPU access inside the container.
# CODA_DEVICE=cpu

# Docker app image build target. Supported values: cpu, cuda.
# This is a build argument consumed by Docker Compose, not a Python runtime
# setting. Changing it requires rebuilding the app image.
# COMPUTE_DEVICE=cpu

# -----------------------------------------------------------------------------
# Docker Compose host ports
# -----------------------------------------------------------------------------

# Ports published on the Docker host for the Neo4j browser and Bolt protocol.
# Change these when the defaults conflict with another host service. These do
# not change Neo4j's internal container ports.
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
